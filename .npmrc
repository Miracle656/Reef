# Expo's CLI + Metro don't support pnpm's default isolated node_modules: they
# resolve packages like `expo` / `expo-modules-core` (which ship TypeScript
# source as `main`) in plain Node and crash on the .ts. A hoisted (npm-like)
# layout is Expo's documented requirement for pnpm monorepos.
node-linker=hoisted

# Network resilience for flaky/throttled connections: more retries, longer
# timeouts, and fewer parallel connections (high concurrency causes ECONNRESET
# on weak links).
fetch-retries=6
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=180000
fetch-timeout=600000
network-concurrency=3
