{
  "expo": {
    "name": "Umbra",
    "slug": "umbra",
    "scheme": "umbra",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": ["expo-router", "expo-secure-store", "expo-web-browser"],
    "experiments": { "typedRoutes": true },
    "ios": { "supportsTablet": true, "bundleIdentifier": "app.umbra.mobile" },
    "android": { "package": "app.umbra.mobile" }
  }
}
