# ReeF web (Next.js) — environment.
# Copy to `.env.local` for local dev; set the SAME keys in the Vercel project
# (Project → Settings → Environment Variables). Every var here is NEXT_PUBLIC_*
# and therefore exposed to the browser — never put a private/secret key here.
# Phase 1 is TESTNET ONLY.

# ---- Sui network ----
NEXT_PUBLIC_SUI_NETWORK=testnet

# ---- Published Move package (packages/move/deployments/testnet.json) ----
NEXT_PUBLIC_UMBRA_PACKAGE_ID=0x0
NEXT_PUBLIC_UMBRA_REGISTRY_ID=0x0

# ---- Enoki zkLogin (PUBLIC key only) + Google OAuth client ----
# The PRIVATE Enoki key lives on the indexer/sponsor service, never here.
# Add your Vercel domain to the Enoki allowed origins and the Google OAuth
# "Authorized JavaScript origins" or sign-in will be rejected.
NEXT_PUBLIC_ENOKI_PUBLIC_API_KEY=enoki_public_xxx
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# ---- Deployed indexer (tRPC API + Enoki sponsor + image/DeepBook proxies) ----
# Local dev default is http://localhost:3001. In production point these at the
# indexer service you deploy separately (Railway / Render / Fly — see DEPLOY.md).
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001
NEXT_PUBLIC_SPONSOR_API_URL=http://localhost:3001/sponsor
